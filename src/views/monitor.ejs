<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>News Monitor — CanadianPulse Admin</title>
<style>
*{margin:0;padding:0;box-sizing:border-box;}
input[type="date"]::-webkit-calendar-picker-indicator{filter:invert(0.7);cursor:pointer;}
body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;background:#0a0a0b;color:#e8e8ee;min-height:100vh;}
.header{background:#111113;border-bottom:1px solid #2a2a30;padding:0 1.5rem;height:56px;display:flex;align-items:center;justify-content:space-between;}
.header-left{display:flex;align-items:center;gap:1rem;}
.logo{font-size:1.1rem;font-weight:700;color:#e8e8ee;text-decoration:none;}
.back-btn{padding:0.35rem 0.875rem;background:transparent;border:1px solid #2a2a30;border-radius:20px;color:#888896;font-size:0.8rem;cursor:pointer;text-decoration:none;transition:all 0.2s;}
.back-btn:hover{border-color:#555560;color:#e8e8ee;}
.page{max-width:1100px;margin:0 auto;padding:2rem 1.5rem;}
.page-title{font-size:1.5rem;font-weight:700;margin-bottom:0.25rem;}
.page-sub{font-size:0.85rem;color:#888896;margin-bottom:2rem;}
.grid{display:grid;grid-template-columns:320px 1fr;gap:1.5rem;align-items:start;}
@media(max-width:768px){.grid{grid-template-columns:1fr;}}
.card{background:#111113;border:1px solid #2a2a30;border-radius:12px;overflow:hidden;margin-bottom:1.5rem;}
.card-header{padding:1rem 1.25rem;border-bottom:1px solid #2a2a30;display:flex;align-items:center;justify-content:space-between;}
.card-title{font-size:0.9rem;font-weight:700;}
.card-body{padding:1.25rem;}
.stat-row{display:flex;gap:1rem;margin-bottom:1.5rem;}
.stat{background:#111113;border:1px solid #2a2a30;border-radius:10px;padding:1rem;flex:1;text-align:center;}
.stat-num{font-size:1.75rem;font-weight:700;color:#e8354a;}
.stat-label{font-size:0.75rem;color:#888896;margin-top:0.2rem;}
.run-btn{width:100%;padding:0.875rem;background:#e8354a;border:none;border-radius:10px;color:#fff;font-size:0.9rem;font-weight:700;cursor:pointer;transition:all 0.2s;margin-bottom:1rem;}
.run-btn:hover{background:#ff4d62;}
.run-btn:disabled{opacity:0.5;cursor:not-allowed;}
.topic-form{display:flex;gap:0.5rem;margin-bottom:1rem;}
.topic-input{flex:1;background:#18181c;border:1px solid #2a2a30;border-radius:8px;padding:0.6rem 0.875rem;color:#e8e8ee;font-size:0.85rem;outline:none;}
.topic-input:focus{border-color:#555560;}
.topic-input::placeholder{color:#555560;}
.add-btn{padding:0.6rem 1rem;background:#2a2a30;border:none;border-radius:8px;color:#e8e8ee;font-size:0.85rem;font-weight:600;cursor:pointer;transition:all 0.2s;white-space:nowrap;}
.add-btn:hover{background:#333340;}
.topic-list{display:flex;flex-direction:column;gap:0.4rem;max-height:300px;overflow-y:auto;}
.topic-item{display:flex;align-items:center;justify-content:space-between;padding:0.5rem 0.75rem;background:#18181c;border-radius:8px;border:1px solid #2a2a30;}
.topic-keyword{font-size:0.85rem;font-weight:600;}
.topic-actions{display:flex;gap:0.4rem;}
.topic-toggle{background:none;border:1px solid #2a2a30;border-radius:20px;padding:0.2rem 0.6rem;font-size:0.72rem;cursor:pointer;color:#888896;transition:all 0.15s;}
.topic-toggle.active{border-color:rgba(46,204,113,0.4);color:#2ecc71;background:rgba(46,204,113,0.08);}
.topic-del{background:none;border:none;cursor:pointer;color:#555560;font-size:1rem;transition:color 0.15s;padding:0 0.25rem;}
.topic-del:hover{color:#e8354a;}
.topic-empty{font-size:0.85rem;color:#555560;text-align:center;padding:1rem 0;}
.table-wrap{overflow-x:auto;}
table{width:100%;border-collapse:collapse;font-size:0.82rem;}
th{text-align:left;padding:0.625rem 0.75rem;color:#555560;font-weight:600;font-size:0.72rem;text-transform:uppercase;letter-spacing:0.04em;border-bottom:1px solid #2a2a30;}
td{padding:0.625rem 0.75rem;border-bottom:1px solid #18181c;color:#888896;vertical-align:top;}
td:first-child{color:#e8e8ee;font-weight:500;max-width:300px;}
tr:last-child td{border-bottom:none;}
tr:hover td{background:#111113;}
.score-badge{display:inline-block;padding:0.2rem 0.5rem;border-radius:6px;font-size:0.72rem;font-weight:700;}
.score-high{background:rgba(46,204,113,0.15);color:#2ecc71;}
.score-mid{background:rgba(245,166,35,0.15);color:#f5a623;}
.score-low{background:rgba(136,136,150,0.15);color:#888896;}
.promoted-badge{background:rgba(232,53,74,0.15);color:#e8354a;padding:0.2rem 0.5rem;border-radius:6px;font-size:0.72rem;font-weight:700;}
.source-tag{background:#18181c;border:1px solid #2a2a30;border-radius:4px;padding:0.15rem 0.4rem;font-size:0.72rem;color:#888896;}
.clear-btn{padding:0.35rem 0.875rem;background:transparent;border:1px solid #2a2a30;border-radius:8px;color:#888896;font-size:0.75rem;cursor:pointer;transition:all 0.2s;}
.clear-btn:hover{border-color:#e8354a;color:#e8354a;}
.log{background:#0a0a0b;border:1px solid #2a2a30;border-radius:8px;padding:0.875rem;font-size:0.8rem;color:#2ecc71;font-family:monospace;min-height:60px;max-height:120px;overflow-y:auto;margin-top:0.75rem;display:none;}
.log.show{display:block;}
</style>
</head>
<body>
<header class="header">
  <div class="header-left">
    <a href="/admin" class="logo">CanadianPulse Admin</a>
    <a href="/admin" class="back-btn">← Dashboard</a>
  </div>
  <span style="font-size:0.8rem;color:#555560;">Logged in as <%= admin.username %></span>
</header>

<div class="page">
  <div class="page-title">🔍 News Monitor</div>
  <div class="page-sub">Auto-discovers and scores Canadian news articles every 4 hours</div>

  <div class="stat-row">
    <div class="stat"><div class="stat-num"><%= stats._count.id || 0 %></div><div class="stat-label">Articles Analyzed</div></div>
    <div class="stat"><div class="stat-num"><%= promoted || 0 %></div><div class="stat-label">Promoted to Pipeline</div></div>
    <div class="stat"><div class="stat-num"><%= topics.filter(t => t.isActive).length %></div><div class="stat-label">Active Topics</div></div>
    <div class="stat"><div class="stat-num"><%= recentCache.filter(c => c.aiScore >= 7).length %></div><div class="stat-label">High Score (7+)</div></div>
  </div>

  <div class="grid">
    <!-- LEFT: Controls -->
    <div>
      <div class="card">
        <div class="card-header"><span class="card-title">⚡ Run Monitor</span></div>
        <div class="card-body">
          <button class="run-btn" onclick="runMonitor()">Run Now</button>
          <div style="font-size:0.78rem;color:#555560;">Auto-runs every 4 hours. Fetches all RSS feeds, filters by topics, scores with AI, promotes high scorers to your story pipeline.</div>
          <div class="log" id="runLog"></div>
        </div>
      </div>

      <div class="card">
        <div class="card-header">
          <span class="card-title">🎯 Monitor Topics</span>
          <button class="clear-btn" onclick="clearCache()">Clear Expired Cache</button>
        </div>
        <div class="card-body">
          <div class="topic-form">
            <input class="topic-input" id="topicInput" placeholder="e.g. carbon tax, Trudeau, housing..." onkeydown="if(event.key==='Enter')addTopic()">
            <button class="add-btn" onclick="addTopic()">+ Add</button>
          </div>
          <div class="topic-list" id="topicList">
            <% if (topics.length === 0) { %>
              <div class="topic-empty">No topics yet. Add keywords to monitor.</div>
            <% } else { %>
              <% topics.forEach(t => { %>
                <div class="topic-item" id="topic-<%= t.id %>">
                  <span class="topic-keyword"><%= t.keyword %></span>
                  <div class="topic-actions">
                    <button class="topic-toggle <%= t.isActive ? 'active' : '' %>" onclick="toggleTopic('<%= t.id %>', this)"><%= t.isActive ? 'Active' : 'Paused' %></button>
                    <button class="topic-del" onclick="deleteTopic('<%= t.id %>')">✕</button>
                  </div>
                </div>
              <% }) %>
            <% } %>
          </div>
        </div>
      </div>

      <!-- SOURCES PANEL -->
      <div class="card">
        <div class="card-header">
          <span class="card-title">📡 News Sources (<span id="activeCount">...</span> active)</span>
          <div style="display:flex;gap:0.5rem;">
            <button class="clear-btn" onclick="toggleAllSources(true)">Enable All</button>
            <button class="clear-btn" onclick="toggleAllSources(false)">Disable All</button>
          </div>
        </div>
        <div class="card-body" style="max-height:400px;overflow-y:auto;">
          <div style="display:flex;flex-direction:column;gap:0.5rem;margin-bottom:1rem;">
            <input class="topic-input" id="newSourceName" placeholder="Source name (e.g. CBC News)">
            <div style="display:flex;gap:0.5rem;">
              <input class="topic-input" id="newSourceUrl" placeholder="RSS feed URL" style="flex:1;">
              <button class="add-btn" onclick="addSource()">+ Add</button>
            </div>
          </div>
          <div id="sourceList" style="display:flex;flex-direction:column;gap:0.4rem;">
            <div style="color:#555560;font-size:0.85rem;padding:1rem;">Loading sources...</div>
          </div>
        </div>
      </div>
    </div>
    <div class="card">
      <div class="card-header">
        <span class="card-title">📰 Articles (<span id="articleCount">...</span>)</span>
        <span style="font-size:0.75rem;color:#555560;">Scores 7+ auto-promoted to pipeline</span>
      </div>
      <div style="padding:0.75rem 1.25rem;border-bottom:1px solid #2a2a30;display:flex;gap:0.5rem;align-items:center;flex-wrap:wrap;">
        <input type="text" id="articleSearch" placeholder="Search articles..." style="flex:1;min-width:180px;padding:0.5rem 0.75rem;background:#0a0a0b;border:1px solid #2a2a30;border-radius:8px;color:#e8e8ee;font-size:0.82rem;outline:none;" />
        <select id="articleLimit" style="padding:0.5rem 0.75rem;background:#0a0a0b;border:1px solid #2a2a30;border-radius:8px;color:#e8e8ee;font-size:0.82rem;cursor:pointer;">
          <option value="50">50 per page</option>
          <option value="100">100 per page</option>
          <option value="200">200 per page</option>
        </select>
        <input type="date" id="articleFrom" style="padding:0.5rem 0.75rem;background:#0a0a0b;border:1px solid #2a2a30;border-radius:8px;color:#e8e8ee;font-size:0.82rem;" title="From date" />
        <span style="color:#555560;font-size:0.8rem;">to</span>
        <input type="date" id="articleTo" style="padding:0.5rem 0.75rem;background:#0a0a0b;border:1px solid #2a2a30;border-radius:8px;color:#e8e8ee;font-size:0.82rem;" title="To date" />
      </div>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Title</th>
              <th>Source</th>
              <th>Score</th>
              <th>Category</th>
              <th>Status</th>
            </tr>
          </thead>
          <tbody id="articlesBody">
            <tr><td colspan="5" style="text-align:center;padding:2rem;color:#555560;">Loading articles...</td></tr>
          </tbody>
        </table>
      </div>
      <div id="articlePagination" style="padding:0.75rem 1.25rem;border-top:1px solid #2a2a30;display:flex;justify-content:space-between;align-items:center;font-size:0.8rem;color:#888896;"></div>
    </div>
  </div>


<script>
// Load sources on page load
async function loadSources() {
  try {
    const res = await fetch('/admin/monitor/sources');
    const data = await res.json();
    renderSources(data.sources);
  } catch(e) { console.error('Failed to load sources'); }
}

function renderSources(sources) {
  const list = document.getElementById('sourceList');
  const active = sources.filter(s => s.isActive).length;
  document.getElementById('activeCount').textContent = active + '/' + sources.length;
  if (!sources.length) {
    list.innerHTML = '<div style="color:#555560;font-size:0.85rem;">No sources yet.</div>';
    return;
  }
  list.innerHTML = sources.map(s => `
    <div class="topic-item" id="source-${s.id}" style="justify-content:space-between;">
      <div style="min-width:0;">
        <div class="topic-keyword" style="font-size:0.82rem;">${s.name}</div>
        <div style="font-size:0.7rem;color:#555560;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:200px;">${s.url}</div>
      </div>
      <div class="topic-actions" style="flex-shrink:0;">
        <button class="topic-toggle ${s.isActive ? 'active' : ''}" onclick="toggleSource('${s.id}', this)">${s.isActive ? 'Active' : 'Off'}</button>
        <button class="topic-del" onclick="deleteSource('${s.id}')">✕</button>
      </div>
    </div>
  `).join('');
}

async function toggleSource(id, btn) {
  try {
    const res = await fetch('/admin/monitor/sources/' + id, { method: 'PATCH' });
    const data = await res.json();
    if (data.success) {
      btn.textContent = data.source.isActive ? 'Active' : 'Off';
      btn.classList.toggle('active', data.source.isActive);
      loadSources();
    }
  } catch(e) { alert('Failed to toggle source'); }
}

async function deleteSource(id) {
  if (!confirm('Remove this source?')) return;
  try {
    await fetch('/admin/monitor/sources/' + id, { method: 'DELETE' });
    loadSources();
  } catch(e) { alert('Failed to delete'); }
}

async function addSource() {
  const name = document.getElementById('newSourceName').value.trim();
  const url = document.getElementById('newSourceUrl').value.trim();
  if (!name || !url) return alert('Name and URL required');
  try {
    const res = await fetch('/admin/monitor/sources', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ name, url })
    });
    const data = await res.json();
    if (data.success) {
      document.getElementById('newSourceName').value = '';
      document.getElementById('newSourceUrl').value = '';
      loadSources();
    }
  } catch(e) { alert('Failed to add source'); }
}

async function toggleAllSources(enable) {
  const res = await fetch('/admin/monitor/sources');
  const data = await res.json();
  const targets = data.sources.filter(s => s.isActive !== enable);
  await Promise.all(targets.map(s =>
    fetch('/admin/monitor/sources/' + s.id, { method: 'PATCH' })
  ));
  loadSources();
}

loadSources();

// Articles search, filter, pagination
let articlePage = 1;
let articleSearchTimer = null;

async function loadArticles() {
  const search = document.getElementById("articleSearch").value.trim();
  const limit = document.getElementById("articleLimit").value;
  const body = document.getElementById("articlesBody");
  const pagination = document.getElementById("articlePagination");
  try {
    const params = new URLSearchParams({ limit, page: articlePage });
    if (search) params.set("search", search);
    const fromDate = document.getElementById("articleFrom").value;
    const toDate = document.getElementById("articleTo").value;
    if (fromDate) params.set("from", fromDate);
    if (toDate) params.set("to", toDate);
    const res = await fetch("/admin/monitor/articles?" + params);
    const data = await res.json();
    document.getElementById("articleCount").textContent = data.total + " total";
    if (!data.articles.length) {
      body.innerHTML = "<tr><td colspan=5 style=text-align:center;padding:2rem;color:#555560;>No articles found.</td></tr>";
      pagination.innerHTML = "";
      return;
    }
    body.innerHTML = data.articles.map(a => {
      const scoreClass = a.aiScore >= 7 ? "score-high" : a.aiScore >= 4 ? "score-mid" : "score-low";
      const commentary = a.aiCommentary ? "<div style=\"font-size:0.75rem;color:#555560;margin-top:0.2rem;font-style:italic;\">" + a.aiCommentary + "</div>" : "";
      const status = a.promoted ? "<span class=\"promoted-badge\">✓ Promoted</span>" : "<span style=\"font-size:0.75rem;color:#555560;\">Monitored</span>";
      return "<tr>" +
        "<td><a href=\"" + a.url + "\" target=_blank style=\"color:#e8e8ee;text-decoration:none;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;\">" + a.title + "</a>" + commentary + "</td>" +
        "<td><span class=source-tag>" + a.sourceName + "</span></td>" +
        "<td><span class=\"score-badge " + scoreClass + "\">" + (a.aiScore || "—") + "/10</span></td>" +
        "<td style=font-size:0.75rem;>" + (a.aiCategory || "—") + "</td>" +
        "<td>" + status + "</td></tr>";
    }).join("");
    var pagBtns = "";
    var prevDisabled = data.page <= 1 ? "opacity:0.3;pointer-events:none;" : "cursor:pointer;";
    var nextDisabled = data.page >= data.pages ? "opacity:0.3;pointer-events:none;" : "cursor:pointer;";
    pagBtns += "<button class=clear-btn style=" + prevDisabled + " onclick=\"articlePage=1;loadArticles()\">«</button>";
    pagBtns += "<button class=clear-btn style=" + prevDisabled + " onclick=\"articlePage--;loadArticles()\">‹</button>";
    var startP = Math.max(1, data.page - 2);
    var endP = Math.min(data.pages, data.page + 2);
    for (var p = startP; p <= endP; p++) {
      var active = p === data.page ? "background:#e8354a;color:#fff;border-color:#e8354a;" : "cursor:pointer;";
      pagBtns += "<button class=clear-btn style=\"" + active + "min-width:32px;\" onclick=\"articlePage=" + p + ";loadArticles()\">" + p + "</button>";
    }
    pagBtns += "<button class=clear-btn style=" + nextDisabled + " onclick=\"articlePage++;loadArticles()\">›</button>";
    pagBtns += "<button class=clear-btn style=" + nextDisabled + " onclick=\"articlePage=" + data.pages + ";loadArticles()\">»</button>";
    pagination.innerHTML = "<span>Page " + data.page + " of " + data.pages + " (" + data.total + " articles)</span>" +
      "<div style=display:flex;gap:0.25rem;>" + pagBtns + "</div>";
  } catch(e) {
    body.innerHTML = "<tr><td colspan=5 style=text-align:center;padding:2rem;color:#e8354a;>Failed to load articles.</td></tr>";
  }
}

document.getElementById("articleSearch").addEventListener("input", function() {
  clearTimeout(articleSearchTimer);
  articleSearchTimer = setTimeout(function() { articlePage = 1; loadArticles(); }, 300);
});
document.getElementById("articleLimit").addEventListener("change", function() {
  articlePage = 1; loadArticles();
});
document.getElementById("articleFrom").addEventListener("change", function() {
  articlePage = 1; loadArticles();
});
document.getElementById("articleTo").addEventListener("change", function() {
  articlePage = 1; loadArticles();
});

loadArticles();

async function runMonitor() {
  const btn = document.querySelector('.run-btn');
  const log = document.getElementById('runLog');
  btn.disabled = true;
  btn.textContent = 'Running...';
  log.classList.add('show');
  log.textContent = '[Monitor] Starting run...\n';
  try {
    const res = await fetch('/admin/monitor/run', { method: 'POST' });
    const data = await res.json();
    if (data.success) {
      log.textContent += `[Monitor] Done. Analyzed: ${data.analyzed}, Promoted: ${data.promoted}\n`;
      log.textContent += '[Monitor] Refreshing page in 2 seconds...';
      setTimeout(() => location.reload(), 2000);
    } else {
      log.textContent += `[Monitor] Error: ${data.error}`;
    }
  } catch(e) {
    log.textContent += `[Monitor] Network error: ${e.message}`;
  } finally {
    btn.disabled = false;
    btn.textContent = 'Run Now';
  }
}

async function addTopic() {
  const input = document.getElementById('topicInput');
  const keyword = input.value.trim();
  if (!keyword) return;
  try {
    const res = await fetch('/admin/monitor/topics', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ keyword })
    });
    const data = await res.json();
    if (data.success) {
      input.value = '';
      const list = document.getElementById('topicList');
      const empty = list.querySelector('.topic-empty');
      if (empty) empty.remove();
      const item = document.createElement('div');
      item.className = 'topic-item';
      item.id = 'topic-' + data.topic.id;
      item.innerHTML = `<span class="topic-keyword">${data.topic.keyword}</span>
        <div class="topic-actions">
          <button class="topic-toggle active" onclick="toggleTopic('${data.topic.id}', this)">Active</button>
          <button class="topic-del" onclick="deleteTopic('${data.topic.id}')">✕</button>
        </div>`;
      list.prepend(item);
    }
  } catch(e) { alert('Failed to add topic'); }
}

async function deleteTopic(id) {
  if (!confirm('Remove this topic?')) return;
  try {
    await fetch('/admin/monitor/topics/' + id, { method: 'DELETE' });
    document.getElementById('topic-' + id)?.remove();
  } catch(e) { alert('Failed to delete'); }
}

async function toggleTopic(id, btn) {
  try {
    const res = await fetch('/admin/monitor/topics/' + id, { method: 'PATCH' });
    const data = await res.json();
    if (data.success) {
      btn.textContent = data.topic.isActive ? 'Active' : 'Paused';
      btn.classList.toggle('active', data.topic.isActive);
    }
  } catch(e) { alert('Failed to toggle'); }
}

async function clearCache() {
  if (!confirm('Clear expired cache entries?')) return;
  try {
    const res = await fetch('/admin/monitor/cache', { method: 'DELETE' });
    const data = await res.json();
    alert(`Cleared ${data.deleted} expired entries`);
  } catch(e) { alert('Failed to clear cache'); }
}
</script>
</body>
</html>
