<div id="settingsModal">
  <div class="settings-box">
    <button class="settings-close" onclick="closeSettings()">✕</button>
    <div class="settings-title">Account Settings</div>
    <div class="settings-label">Avatar Color</div>
    <div class="color-picker" id="colorPicker"></div>
    <div class="settings-label">Change Username</div>
    <input class="settings-input" id="settingsUsername" placeholder="New username">
    <div class="settings-label">Change Password</div>
    <input class="settings-input" id="settingsPassword" type="password" placeholder="New password (leave blank to keep)">
    <button class="settings-save" onclick="saveSettings()">Save Changes</button>
  </div>
</div>

<script>
const AVATAR_COLORS = ["#e8354a","#4a9eff","#2ecc71","#f5a623","#9b59b6","#e67e22","#1abc9c","#e91e63"];
let selectedAvatarColor = null;

function openSettings() {
  const modal = document.getElementById("settingsModal");
  modal.classList.add("open");
  const picker = document.getElementById("colorPicker");
  picker.innerHTML = "";
  const currentColor = currentUser?.avatarUrl || getAvatarColor(currentUser?.username || "U");
  AVATAR_COLORS.forEach(color => {
    const sw = document.createElement("div");
    sw.className = "color-swatch" + (color === currentColor ? " selected" : "");
    sw.style.background = color;
    sw.textContent = currentUser?.username?.[0]?.toUpperCase() || "U";
    sw.onclick = () => {
      document.querySelectorAll(".color-swatch").forEach(s => s.classList.remove("selected"));
      sw.classList.add("selected");
      selectedAvatarColor = color;
    };
    picker.appendChild(sw);
  });
  selectedAvatarColor = currentColor;
  document.getElementById("settingsUsername").value = currentUser?.username || "";
  document.getElementById("settingsPassword").value = "";
}

function closeSettings() {
  document.getElementById("settingsModal").classList.remove("open");
}

async function saveSettings() {
  const username = document.getElementById("settingsUsername").value.trim();
  const password = document.getElementById("settingsPassword").value;
  const token = localStorage.getItem("cp_token");
  const body = {};
  if (username && username !== currentUser.username) body.username = username;
  if (password) body.password = password;
  if (selectedAvatarColor) body.avatarColor = selectedAvatarColor;
  if (Object.keys(body).length === 0) { closeSettings(); return; }
  try {
    const res = await fetch("/api/auth/update", {
      method: "PUT",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify(body)
    });
    const data = await res.json();
    if (data.error) { showToast(data.error, "error"); return; }
    localStorage.setItem("cp_token", data.token);
    localStorage.setItem("cp_user", JSON.stringify(data.user));
    currentUser = data.user;
    updateAuthUI();
    closeSettings();
    showToast("✅ Settings saved!");
  } catch(e) {
    showToast("Failed to save settings", "error");
  }
}
</script>

<script>
function showForgotPassword() {
  const mob = document.querySelector(".mob");
  mob.dataset.original = mob.innerHTML;
  mob.innerHTML = `
    <div style="padding:0.5rem 0 1.5rem;">
      <div style="font-size:1.1rem;font-weight:700;margin-bottom:0.25rem;">Reset Password</div>
      <div style="font-size:0.85rem;color:var(--text3);margin-bottom:1.25rem;">Enter your email to get a reset link.</div>
      <div id="forgotMsg" style="display:none;padding:0.75rem 1rem;border-radius:10px;font-size:0.85rem;margin-bottom:1rem;"></div>
      <input type="email" class="mof" id="forgotEmail" placeholder="Your email address" style="margin-bottom:0.75rem;">
      <div id="resetLinkBox" style="display:none;margin-bottom:1rem;padding:0.75rem 1rem;background:var(--bg3);border:1px solid var(--border);border-radius:10px;font-size:0.8rem;color:var(--text2);word-break:break-all;"></div>
      <button class="mosub" onclick="submitForgotPassword()">Generate Reset Link</button>
      <div style="text-align:center;margin-top:1rem;"><a href="#" onclick="restoreLoginModal()" style="font-size:0.82rem;color:var(--text3);text-decoration:none;">← Back to Log In</a></div>
    </div>
  `;
}

function restoreLoginModal() {
  const mob = document.querySelector(".mob");
  if (mob.dataset.original) mob.innerHTML = mob.dataset.original;
  switchTab("login");
}

async function submitForgotPassword() {
  const email = document.getElementById('forgotEmail').value.trim();
  const msg = document.getElementById('forgotMsg');
  const linkBox = document.getElementById('resetLinkBox');
  if (!email) { showForgotMsg('Please enter your email.', 'error'); return; }
  try {
    const res = await fetch('/api/auth/forgot-password', {
      method: 'POST',
      credentials: 'include',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ email })
    });
    const data = await res.json();
    if (data.error) { showForgotMsg(data.error, 'error'); return; }
    showForgotMsg('Reset link generated! Click it below to reset your password.', 'success');
    linkBox.style.display = 'block';
    linkBox.innerHTML = `<a href="${data.resetLink}" style="color:var(--red);">${window.location.origin}${data.resetLink}</a>`;
  } catch(e) {
    showForgotMsg('Something went wrong. Try again.', 'error');
  }
}

function showForgotMsg(text, type) {
  const msg = document.getElementById('forgotMsg');
  msg.textContent = text;
  msg.style.display = 'block';
  msg.style.background = type === 'success' ? 'rgba(46,204,113,0.15)' : 'rgba(232,53,74,0.15)';
  msg.style.border = type === 'success' ? '1px solid rgba(46,204,113,0.3)' : '1px solid rgba(232,53,74,0.3)';
  msg.style.color = type === 'success' ? '#2ecc71' : '#e8354a';
}
</script>
