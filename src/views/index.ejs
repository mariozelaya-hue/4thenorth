async function handleAuth() {
  const isLogin = document.getElementById('tab-login').classList.contains('active');
  const email = document.getElementById('femail').value.trim();
  const password = document.getElementById('fpassword').value;
  const username = document.getElementById('fusername')?.value.trim();

  if (!email || !password) return showToast('Please fill in all fields', 'error');
  if (!isLogin && !username) return showToast('Please choose a username', 'error');

  const endpoint = isLogin ? '/api/auth/login' : '/api/auth/register';
  const body = isLogin ? { email, password } : { email, password, username };

  try {
    const res = await fetch(endpoint, {
      method: 'POST',
      credentials: 'include',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(body)
    });
    const data = await res.json();

    if (!res.ok) return showToast(data.error || 'Something went wrong', 'error');

    localStorage.setItem('cp_token', data.token);
    localStorage.setItem('cp_user', JSON.stringify(data.user));
    currentUser = data.user;
    updateAuthUI();
    closeModal();
    showToast('🇨🇦 Welcome, ' + data.user.username + '!');
    if (pending) { pending(); pending = null; }
  } catch (e) {
    showToast('Network error, try again', 'error');
  }
}

function updateAuthUI() {
  const user = currentUser;
  const loginBtn = document.getElementById("loginBtn");
  const joinBtn = document.getElementById("joinBtn");
  const profileWrap = document.getElementById("profileWrap");
  const profileAvatar = document.getElementById("profileAvatar");
  const profileName = document.getElementById("profileName");
  const pdUsername = document.getElementById("pdUsername");
  const pdEmail = document.getElementById("pdEmail");
  if (user) {
    if (loginBtn) loginBtn.style.display = "none";
    if (joinBtn) joinBtn.style.display = "none";
    if (profileWrap) profileWrap.style.display = "flex";
    const jpBtn = document.getElementById("joinPulseBtn"); if (jpBtn) jpBtn.style.display = "none";
    const ctaSub = document.getElementById("leftCtaSub"); if (ctaSub) ctaSub.style.display = "none";
    const color = user.avatarUrl || getAvatarColor(user.username);
    if (profileAvatar) { profileAvatar.textContent = user.username[0].toUpperCase(); profileAvatar.style.background = color; }
    if (profileName) profileName.textContent = user.username;
    if (pdUsername) pdUsername.textContent = user.username;
    if (pdEmail) pdEmail.textContent = user.email || "";
  } else {
    if (loginBtn) { loginBtn.style.display = ""; loginBtn.textContent = "Log In"; loginBtn.onclick = () => openModal("login"); }
    if (joinBtn) { joinBtn.style.display = ""; joinBtn.textContent = "Join Free"; joinBtn.onclick = () => openModal("signup"); }
    if (profileWrap) profileWrap.style.display = "none";
    const jpBtn = document.getElementById("joinPulseBtn"); if (jpBtn) jpBtn.style.display = "";
    const ctaSub = document.getElementById("leftCtaSub"); if (ctaSub) ctaSub.style.display = "";
  }
}

