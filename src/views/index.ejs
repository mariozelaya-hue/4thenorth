// LIKES
async function likeStory(storyId, pill) {
  if (pill.dataset.pending) return;
  pill.dataset.pending = '1';
  const countEl = pill.querySelector(".hcount");
  const btn = pill.querySelector(".hbtn");
  const svg = pill.querySelector(".hsvg");
  const liked = pill.classList.contains("liked");
  try {
    const res = await fetch("/api/stories/" + storyId + "/like", {
      method: 'POST',
      credentials: 'include',
      headers: { "Content-Type": "application/json" }
    });
    const data = await res.json();
    if (data.liked) {
      pill.classList.add("liked");
      btn.style.color = "#e8354a";
      svg.style.fill = "var(--red)";
      svg.style.stroke = "var(--red)";
      countEl.textContent = fmtV(parseV(countEl.textContent) + 1);
    } else {
      pill.classList.remove("liked");
      btn.style.color = "";
      svg.style.fill = "none";
      svg.style.stroke = "currentColor";
      countEl.textContent = fmtV(parseV(countEl.textContent) - 1);
