<script>

let currentSort = 'latest';
let currentCategory = 'all';
let pending = null;
let currentUser = null;
try { const _u = localStorage.getItem("cp_user"); if (_u) currentUser = JSON.parse(_u); } catch(e) {}

// Check server session on page load (handles Google OAuth)
let userLikedIds = new Set();
let userSavedIds = new Set();

async function loadUserState() {
  if (!currentUser) return;
  try {
    const [likesRes, savesRes] = await Promise.all([
      fetch('/api/likes'),
      fetch('/api/saves/ids')
    ]);
    if (likesRes.ok) {
      const d = await likesRes.json();
      userLikedIds = new Set(d.storyIds || []);
    }
    if (savesRes.ok) {
      const d = await savesRes.json();
      userSavedIds = new Set(d.storyIds || []);
    }
    // Mark all like/save buttons using their IDs
    userLikedIds.forEach(id => {
      const pill = document.getElementById('like-' + id);
      if (pill) {
        const btn = pill.querySelector('.hbtn');
        const svg = pill.querySelector('.hsvg');
        if (btn) btn.classList.add('liked');
        if (svg) { svg.style.fill = 'var(--red)'; svg.style.stroke = 'var(--red)'; }
      }
    });
    userSavedIds.forEach(id => {
      const el = document.getElementById('save-' + id);
      if (el) el.classList.add('saved');
    });
  } catch(e) {}
}

(async function checkSession() {
  try {
    const res = await fetch('/api/auth/me');
    if (res.ok) {
      const data = await res.json();
      if (data.user) {
        currentUser = data.user;
        localStorage.setItem('cp_user', JSON.stringify(data.user));
      }
    }
  } catch(e) {}
  updateAuthUI();
  await loadUserState();
})();


// LIVE FEED
async function loadFeed() {
  const pinned = document.getElementById("pinnedStoryCard");
  if (pinned) pinned.style.display = "";
  try {
    const res = await fetch(`/api/feed?sort=${currentSort}&category=${currentCategory}`);
    const data = await res.json();
    const container = document.getElementById('feedContainer');
    
    if (!data.stories || data.stories.length === 0) {
      container.innerHTML = '<div style="padding:2rem;text-align:center;color:var(--text3);">No stories yet.</div>';
      return;
    }
    
    renderStories(data, container);
    setTimeout(restoreSaveStates, 100);
    setTimeout(restoreLikeStates, 150);
  } catch(e) {
    console.error('Feed error:', e);
    document.getElementById('feedContainer').innerHTML = '<div style="padding:2rem;text-align:center;color:var(--text3);">Failed to load stories.</div>';
  }
}

function renderStories(data, container, append=false) {
    const html = data.stories.map((s, i) => {
      const score = parseFloat(s.viralScore) || 0;
      const scoreRounded = Math.round(score);
      const timeAgo = getTimeAgo(s.publishedAt);
      const tag = ''; // editorial tag hidden on frontend
      const category = s.category ? `<span class="tag">${s.category}</span>` : '';
      const breaking = s.isBreaking ? `<span class="tag live">⬤ Breaking</span>` : '';
      const featured = s.isFeatured ? `<span class="tag">⭐ Featured</span>` : '';
      const commentary = s.commentary ? `<div class="tr-line">${s.commentary}</div>` : '';

      // Auto layout logic — position based
      let ratio = 'ratio-wide';
      let titleSize = '';
      let cardClass = 'post-card';

      const layouts = [
        { ratio: 'ratio-ultra', title: 'font-size:1.5rem;font-family:"DM Serif Display",serif;', card: 'post-card card-hero' },
        { ratio: 'ratio-land',  title: 'font-size:1.1rem;', card: 'post-card' },
        { ratio: 'ratio-sq',    title: 'font-size:0.95rem;', card: 'post-card' },
        { ratio: 'ratio-wide',  title: 'font-size:1.05rem;', card: 'post-card' },
        { ratio: 'ratio-tall',  title: 'font-size:1rem;font-family:"DM Serif Display",serif;', card: 'post-card' },
        { ratio: 'ratio-land',  title: 'font-size:0.95rem;', card: 'post-card' },
      ];

      // Use manual cardStyle if set, otherwise random layout
      if (s.cardStyle && s.cardStyle !== '') {
        ratio = s.cardStyle;
      } else {
        const layout = layouts[Math.floor(Math.random() * layouts.length)];
        ratio = layout.ratio;
        titleSize = layout.title;
        cardClass = layout.card;
      }

      // Override if breaking
      if (s.isBreaking) { titleSize = 'font-size:1.1rem;'; }

      const img = s.imageUrl ? `<div class="media ${ratio}" onclick="event.stopPropagation()"><img src="${s.imageUrl}" alt="${s.originalTitle}" loading="lazy" onerror="this.parentElement.style.display='none'"></div>` : '';

      return `
  <article class="${cardClass}" style="cursor:pointer" onclick="window.open('${s.sourceUrl}','_blank');return false;">
    <div class="pc">
      <div class="pmeta">${breaking}${tag}${category}${featured}<span style="color:var(--text3);font-size:0.85em">${s.sourceName || ''}</span><span style="color:var(--text3)">·</span><span>${timeAgo}</span><span class="score">${scoreRounded}/10</span></div>
      <h3 class="ptitle" style="${titleSize}">${s.originalTitle}</h3>
      ${commentary}
      ${img}
      <div class="abar">
        <div class="hpill" id="like-${s.id}" onclick="event.stopPropagation();requireLogin(()=>likeStory('${s.id}',this))">
          <button class="hbtn"><svg width="18" height="18" viewBox="0 0 24 24"><path class="hsvg" d="M12 21C12 21 3 14.5 3 8.5C3 5.42 5.42 3 8.5 3C10.24 3 11.91 3.81 13 5.08C14.09 3.81 15.76 3 17.5 3C20.58 3 23 5.42 23 8.5C23 14.5 12 21 12 21Z"/></svg></button>
          <span class="hcount">${fmtV(s.likes || 0)}</span>
        </div>
        <button class="abtn" onclick="event.stopPropagation();toggleComments('${s.id}',this)"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>Comment${s._count && s._count.comments > 0 ? ' <span style="font-weight:700;color:var(--text)">' + s._count.comments + '</span>' : ''}</button>
        <button class="abtn" onclick="event.stopPropagation();sharePost(this)"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12v8a2 2 0 002 2h12a2 2 0 002-2v-8M16 6l-4-4-4 4M12 2v13"/></svg>Share</button>
        <button class="abtn save-btn" id="save-${s.id}" onclick="event.stopPropagation();requireLogin(()=>toggleSave('${s.id}',this))"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21l-7-5-7 5V5a2 2 0 012-2h10a2 2 0 012 2z"/></svg>Save</button>
      </div>
      <div class="comment-section" id="comments-${s.id}" style="display:none" onclick="event.stopPropagation()">
        <div class="comment-list" id="comment-list-${s.id}"></div>
        <div class="comment-input-row">
          <input class="comment-input" id="comment-input-${s.id}" placeholder="Add a comment…" maxlength="1000">
          <button class="comment-submit" onclick="submitComment('${s.id}')">Post</button>
        </div>
      </div>
    </div>
  </article>`;
    }).join('');
    if (append) {
      container.innerHTML += html;
    } else {
      container.innerHTML = html;
    }
    // Re-apply liked/saved state after render
    if (currentUser) setTimeout(() => loadUserState(), 100);
}

async function loadFeedCatch() {
  try {
    await loadFeed();
  } catch(e) {
    console.error('loadFeedCatch error:', e);
  }
}

// Load trending topics
async function loadTrends() {
  try {
    const res = await fetch('/api/trends');
    const data = await res.json();
    const list = document.getElementById('trending-list');
    if (!data.trends || data.trends.length === 0) {
      list.innerHTML = '<div class="trending-item"><div class="trending-label">No trends available</div></div>';
      return;
    }
    list.innerHTML = data.trends.map((t, i) =>
      '<div class="trending-item" style="cursor:pointer" onclick="window.open(\'' + t.url + '\', \'_blank\')">' +
      '<div class="trending-label">🔥 Trending in Canada</div>' +
      '<div class="trending-topic">' + t.title + '</div>' +
      '<div class="trending-posts">' + t.traffic + '</div>' +
      '</div>'
    ).join('');
  } catch(e) {
    console.error('Trends error:', e);
  }
}

function searchTrend(term) {
  const overlay = document.getElementById('searchOverlay');
  const input = document.getElementById('searchInput');
  if (input) {
    input.value = term;
