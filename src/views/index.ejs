// VIDEO
let vPlaying=false,vProg=0,vInt=null;
const vTotal=1478;
function toggleVideo(){
  const c=document.getElementById('vidC');
  const btn=document.getElementById('vPlayBtn');
  const poster=document.getElementById('vPoster');
  vPlaying=!vPlaying;
  c.classList.toggle('playing',vPlaying);
  btn.textContent=vPlaying?'⏸':'▶';
  if(vPlaying){
    poster.style.opacity='0.25';
    vInt=setInterval(()=>{
      vProg=Math.min(vProg+0.08,100);
      document.getElementById('vFill').style.width=vProg+'%';
      const e=Math.floor(vProg/100*vTotal);
      document.getElementById('vTime').textContent=ft(e)+' / 24:38';
      if(vProg>=100){clearInterval(vInt);vPlaying=false;btn.textContent='▶';c.classList.remove('playing');poster.style.opacity='1';}
    },100);
  } else {
    clearInterval(vInt);poster.style.opacity='1';
  }
}
function scrubVideo(e){
  const b=document.getElementById('vProgress');
  const r=b.getBoundingClientRect();
  const p=Math.max(0,Math.min(1,(e.clientX-r.left)/r.width));
  vProg=p*100;
  document.getElementById('vFill').style.width=vProg+'%';
  document.getElementById('vTime').textContent=ft(Math.floor(p*vTotal))+' / 24:38';
}
function ft(s){return Math.floor(s/60)+':'+String(s%60).padStart(2,'0');}

// MODAL
let emailFormOpen=false;

function openModal(m){
  document.getElementById('modal').classList.add('open');
  switchTab(m);
  // Reset email form to collapsed each time modal opens
  emailFormOpen=false;
  document.getElementById('emailFormWrap').classList.remove('open');
  document.getElementById('emailToggle').classList.remove('open');
  document.getElementById('emailToggle').querySelector('.email-toggle-chevron').style.transform='';
}
function closeModal(){document.getElementById('modal').classList.remove('open');pending=null;}

function switchTab(m){
  const s=m==='signup';
  document.getElementById('tab-signup').classList.toggle('active',s);
  document.getElementById('tab-login').classList.toggle('active',!s);
  document.getElementById('mtitle').innerHTML=s?'Join <span style="color:var(--red)">CanadianPulse</span>':'Welcome <span style="color:var(--red)">Back</span>';
  document.getElementById('msub').textContent=s?'Where Canada debates what matters.':'Good to have you back.';
  // Update social button labels
  document.getElementById('google-label').textContent=s?'Continue with Google':'Sign in with Google';
  document.getElementById('apple-label').textContent=s?'Continue with Apple':'Sign in with Apple';
  document.getElementById('fb-label').textContent=s?'Continue with Facebook':'Sign in with Facebook';
  // Username field only for signup
  const uField=document.getElementById('fusername');
  if(uField) uField.style.display=s?'block':'none';
  document.getElementById('msubmit').textContent=s?'Create Free Account':'Log In';
  document.getElementById('emailToggleLabel').textContent=s?'Continue with Email':'Sign in with Email';
}

function toggleEmailForm(){
  emailFormOpen=!emailFormOpen;
  const wrap=document.getElementById('emailFormWrap');
  const toggle=document.getElementById('emailToggle');
  const chevron=toggle.querySelector('.email-toggle-chevron');
  wrap.classList.toggle('open',emailFormOpen);
  toggle.classList.toggle('open',emailFormOpen);
  chevron.style.transform=emailFormOpen?'rotate(90deg)':'';
  // Scroll modal body down slightly so form is visible
  if(emailFormOpen){
    setTimeout(()=>{
      wrap.scrollIntoView({behavior:'smooth',block:'nearest'});
    },200);
  }
}

async function handleAuth() {
  const isLogin = document.getElementById('tab-login').classList.contains('active');
  const email = document.getElementById('femail').value.trim();
  const password = document.getElementById('fpassword').value;
  const username = document.getElementById('fusername')?.value.trim();

  if (!email || !password) return showToast('Please fill in all fields', 'error');
  if (!isLogin && !username) return showToast('Please choose a username', 'error');

  const endpoint = isLogin ? '/api/auth/login' : '/api/auth/register';
  const body = isLogin ? { email, password } : { email, password, username };

  try {
    const res = await fetch(endpoint, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(body)
    });
    const data = await res.json();

    if (!res.ok) return showToast(data.error || 'Something went wrong', 'error');

    localStorage.setItem('cp_token', data.token);
    localStorage.setItem('cp_user', JSON.stringify(data.user));
    currentUser = data.user;
    updateAuthUI();
    closeModal();
    showToast('🇨🇦 Welcome, ' + data.user.username + '!');
    if (pending) { pending(); pending = null; }
  } catch (e) {
    showToast('Network error, try again', 'error');
  }
}

function updateAuthUI() {
  const user = currentUser;
  const loginBtn = document.querySelector('.btn-outline');
  const joinBtn = document.querySelector('.btn-red');
  if (user) {
    if (loginBtn) loginBtn.textContent = user.username;
    if (joinBtn) { joinBtn.textContent = 'Log Out'; joinBtn.onclick = logout; }
  } else {
    if (loginBtn) { loginBtn.textContent = 'Log In'; loginBtn.onclick = () => openModal('login'); }
    if (joinBtn) { joinBtn.textContent = 'Join Free'; joinBtn.onclick = () => openModal('signup'); }
  }
}

function logout() {
  localStorage.removeItem('cp_token');
  localStorage.removeItem('cp_user');
  currentUser = null;
  updateAuthUI();
  showToast('Logged out');
}

function requireLogin(cb) {
  if (currentUser) { cb(); return; }
  pending = cb;
  openModal('signup');
}

// Init auth state on page load
try {
  const stored = localStorage.getItem('cp_user');
  const token = localStorage.getItem('cp_token');
  if (stored && token) {
    currentUser = JSON.parse(stored);
    updateAuthUI();
  }
} catch(e) {}

