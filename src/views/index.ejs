function closeShareMenu() {
  document.querySelectorAll('.share-menu').forEach(m => m.remove());
}

function copyLink(url) {
  navigator.clipboard.writeText(url).then(() => showToast('🔗 Link copied!'));
  closeShareMenu();
}
async function showSaved(el) {
  document.querySelectorAll('.nav-item').forEach(x => x.classList.remove('active'));
  if (el) el.classList.add('active');
  currentCategory = 'saved';
  const container = document.getElementById('feedContainer');
  container.innerHTML = '<div style="padding:2rem;text-align:center;color:var(--text3);">Loading saved stories...</div>';
  const token = localStorage.getItem('cp_token');
  try {
    const res = await fetch('/api/saves', { headers: { 'Authorization': 'Bearer ' + token } });
    const data = await res.json();
    if (!data.stories || data.stories.length === 0) {
      container.innerHTML = '<div style="padding:2rem;text-align:center;color:var(--text3);">No saved stories yet.</div>';
      return;
    }
    // Reuse loadFeed render logic by temporarily setting stories
    const fakeData = { stories: data.stories, total: data.stories.length };
    renderStories(fakeData, container);
  } catch(e) {
    container.innerHTML = '<div style="padding:2rem;text-align:center;color:var(--text3);">Failed to load saved stories.</div>';
  }
}

async function toggleSave(storyId, btn) {
  const token = localStorage.getItem('cp_token');
  try {
    const res = await fetch('/api/saves/' + storyId, {
      method: 'POST',
      headers: { 'Authorization': 'Bearer ' + token }
    });
    const data = await res.json();
    if (data.saved) {
      btn.classList.add('saved');
      btn.style.color = 'var(--gold, #f5a623)';
      btn.style.borderColor = 'rgba(245,166,35,0.3)';
      showToast('⌂ Saved!');
    } else {
      btn.classList.remove('saved');
      btn.style.color = '';
      btn.style.borderColor = '';
      showToast('Removed from saved');
    }
  } catch(e) {
    showToast('Failed to save', 'error');
  }
}
