<script>

let currentSort = 'latest';
let currentCategory = 'all';
let pending = null;
let currentUser = null;

// LIVE FEED
async function loadFeed() {
  try {
    const res = await fetch(`/api/feed?sort=${currentSort}&category=${currentCategory}`);
    const data = await res.json();
    const container = document.getElementById('feedContainer');
    
    if (!data.stories || data.stories.length === 0) {
      container.innerHTML = '<div style="padding:2rem;text-align:center;color:var(--text3);">No stories yet.</div>';
      return;
    }
    
    renderStories(data, container);
  } catch(e) {
    console.error('Feed error:', e);
    document.getElementById('feedContainer').innerHTML = '<div style="padding:2rem;text-align:center;color:var(--text3);">Failed to load stories.</div>';
  }
}

function renderStories(data, container) {
    container.innerHTML = data.stories.map((s, i) => {
      const score = parseFloat(s.viralScore) || 0;
      const scoreRounded = Math.round(score);
      const timeAgo = getTimeAgo(s.publishedAt);
      const tag = ''; // editorial tag hidden on frontend
      const category = s.category ? `<span class="tag">${s.category}</span>` : '';
      const breaking = s.isBreaking ? `<span class="tag live">⬤ Breaking</span>` : '';
      const featured = s.isFeatured ? `<span class="tag">⭐ Featured</span>` : '';
      const commentary = s.commentary ? `<div class="tr-line">${s.commentary}</div>` : '';

      // Auto layout logic — position based
      let ratio = 'ratio-wide';
      let titleSize = '';
      let cardClass = 'post-card';

      const layouts = [
        { ratio: 'ratio-ultra', title: 'font-size:1.5rem;font-family:"DM Serif Display",serif;', card: 'post-card card-hero' },
        { ratio: 'ratio-land',  title: 'font-size:1.1rem;', card: 'post-card' },
        { ratio: 'ratio-sq',    title: 'font-size:0.95rem;', card: 'post-card' },
        { ratio: 'ratio-wide',  title: 'font-size:1.05rem;', card: 'post-card' },
        { ratio: 'ratio-tall',  title: 'font-size:1rem;font-family:"DM Serif Display",serif;', card: 'post-card' },
        { ratio: 'ratio-land',  title: 'font-size:0.95rem;', card: 'post-card' },
      ];

      // Use manual cardStyle if set, otherwise random layout
      if (s.cardStyle && s.cardStyle !== '') {
        ratio = s.cardStyle;
      } else {
        const layout = layouts[Math.floor(Math.random() * layouts.length)];
        ratio = layout.ratio;
        titleSize = layout.title;
        cardClass = layout.card;
      }

      // Override if breaking
      if (s.isBreaking) { titleSize = 'font-size:1.1rem;'; }

      const img = s.imageUrl ? `<div class="media ${ratio}" onclick="event.stopPropagation()"><img src="${s.imageUrl}" alt="${s.originalTitle}" loading="lazy" onerror="this.parentElement.style.display='none'"></div>` : '';

      return `
  <article class="${cardClass}" onclick="window.open('${s.sourceUrl}','_blank')">
    <div class="pc">
      <div class="pmeta">${breaking}${tag}${category}${featured}<span style="color:var(--text3);font-size:0.85em">${s.sourceName || ''}</span><span style="color:var(--text3)">·</span><span>${timeAgo}</span><span class="score">${scoreRounded}/10</span></div>
      <h3 class="ptitle" style="${titleSize}">${s.originalTitle}</h3>
      ${commentary}
      ${img}
      <div class="abar">
        <div class="hpill" onclick="event.stopPropagation();requireLogin(()=>likeStory('${s.id}',this))">
          <button class="hbtn"><svg width="18" height="18" viewBox="0 0 24 24"><path class="hsvg" d="M12 21C12 21 3 14.5 3 8.5C3 5.42 5.42 3 8.5 3C10.24 3 11.91 3.81 13 5.08C14.09 3.81 15.76 3 17.5 3C20.58 3 23 5.42 23 8.5C23 14.5 12 21 12 21Z"/></svg></button>
          <span class="hcount">${fmtV(s.likes || 0)}</span>
        </div>
        <button class="abtn" onclick="event.stopPropagation();toggleComments('${s.id}',this)"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>Comment</button>
        <button class="abtn" onclick="event.stopPropagation();sharePost(this)"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12v8a2 2 0 002 2h12a2 2 0 002-2v-8M16 6l-4-4-4 4M12 2v13"/></svg>Share</button>
        <button class="abtn save-btn" id="save-${s.id}" onclick="event.stopPropagation();requireLogin(()=>toggleSave('${s.id}',this))"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21l-7-5-7 5V5a2 2 0 012-2h10a2 2 0 012 2z"/></svg>Save</button>
      </div>
      <div class="comment-section" id="comments-${s.id}" style="display:none" onclick="event.stopPropagation()">
        <div class="comment-list" id="comment-list-${s.id}"></div>
        <div class="comment-input-row">
          <input class="comment-input" id="comment-input-${s.id}" placeholder="Add a comment…" maxlength="1000">
          <button class="comment-submit" onclick="submitComment('${s.id}')">Post</button>
        </div>
      </div>
    </div>
  </article>`;
    }).join('');
}

async function loadFeedCatch() {
  try {
    await loadFeed();

// Load trending topics
async function loadTrends() {
  try {
    const res = await fetch('/api/trends');
    const data = await res.json();
    const list = document.getElementById('trending-list');
    if (!data.trends || data.trends.length === 0) {
      list.innerHTML = '<div class="trending-item"><div class="trending-label">No trends available</div></div>';
      return;
    }
    list.innerHTML = data.trends.map(t =>
      '<div class="trending-item" style="cursor:pointer" onclick="searchTrend(\'' + t.title.replace(/'/g, "\\'") + '\')">' +
      '<div class="trending-label">🔥 Trending in Canada</div>' +
      '<div class="trending-topic">' + t.title + '</div>' +
      '<div class="trending-posts">' + t.traffic + ' searches</div>' +
      '</div>'
    ).join('');
  } catch(e) {
    console.error('Trends error:', e);
  }
}

function searchTrend(term) {
  const overlay = document.getElementById('searchOverlay');
  const input = document.getElementById('searchInput');
  if (input) {
    input.value = term;
    overlay.classList.add('open');
    input.focus();
    input.dispatchEvent(new Event('input'));
  }
}

loadTrends();
  } catch(e) {
    console.error('Feed error:', e);
    document.getElementById('feedContainer').innerHTML = '<div style="padding:2rem;text-align:center;color:var(--text3);">Failed to load stories.</div>';
  }
}

function getTimeAgo(dateStr) {
  if (!dateStr) return '';
  const diff = Date.now() - new Date(dateStr).getTime();
  const mins = Math.floor(diff / 60000);
  const hrs = Math.floor(mins / 60);
  const days = Math.floor(hrs / 24);
  if (days > 0) return days + 'd ago';
  if (hrs > 0) return hrs + 'h ago';
  if (mins > 0) return mins + 'm ago';
  return 'just now';
}

loadFeed();


// LIKES
async function likeStory(storyId, pill) {
  const countEl = pill.querySelector('.hcount');
  const btn = pill.querySelector('.hbtn');
  const liked = pill.classList.contains('liked');
  pill.classList.toggle('liked');
  const count = parseV(countEl.textContent);
  countEl.textContent = fmtV(liked ? count - 1 : count + 1);
  btn.style.color = liked ? '' : '#e8354a';
  try {
    const token = localStorage.getItem('cp_token');
    await fetch('/api/stories/' + storyId + '/like', {
      method: 'POST',
      headers: { 'Authorization': 'Bearer ' + token, 'Content-Type': 'application/json' },
      body: JSON.stringify({ liked: !liked })
    });
  } catch(e) {}
}

// COMMENTS
async function toggleComments(storyId, btn) {
  const section = document.getElementById('comments-' + storyId);
  if (!section) return;
  const isOpen = section.style.display !== 'none';
  section.style.display = isOpen ? 'none' : 'block';
  if (!isOpen) await loadComments(storyId);
}

async function loadComments(storyId) {
  const list = document.getElementById('comment-list-' + storyId);
  if (!list) return;
  list.innerHTML = '<div class="comment-empty">Loading...</div>';
  try {
    const res = await fetch('/api/comments/' + storyId);
    const data = await res.json();
    if (!data.comments || data.comments.length === 0) {
      list.innerHTML = '<div class="comment-empty">No comments yet. Be the first!</div>';
      return;
    }
    function buildComment(c, isReply) {
      const replies = (!isReply && c.replies && c.replies.length) 
        ? '<div class="comment-replies">' + c.replies.map(r => buildComment(r, true)).join('') + '</div>' 
        : '';
      return '<div class="comment-item' + (isReply ? ' comment-reply' : '') + '">' +
        '<div class="comment-avatar">' + c.user.username[0].toUpperCase() + '</div>' +
        '<div class="comment-body-wrap">' +
        '<div class="comment-header"><span class="comment-author">' + c.user.username + '</span><span class="comment-time">' + getTimeAgo(c.createdAt) + '</span></div>' +
        '<div class="comment-text">' + c.body + '</div>' +
        '<div class="comment-actions">' +
        '<div class="comment-vote">' +
        '<button class="comment-vote-btn up" onclick="voteComment(this,\'' + c.id + '\',1)">▲</button>' +
        '<span class="comment-vote-count">' + (c.likes || 0) + '</span>' +
        '<button class="comment-vote-btn down" onclick="voteComment(this,\'' + c.id + '\',-1)">▼</button>' +
        '</div>' +
        (isReply ? '' : '<button class="comment-reply-btn" onclick="toggleReply(this,\'' + c.id + '\',\'' + storyId + '\')">Reply</button>') +
        (currentUser && currentUser.id === c.userId ? '<button class="comment-reply-btn" style="color:#e8354a" onclick="deleteComment(\'' + c.id + '\',\'' + storyId + '\')">Delete</button>' : '') +
        '</div>' +
        replies +
        '</div></div>';
    }
    list.innerHTML = '<div class="comment-count-label">' + data.comments.length + ' comment' + (data.comments.length !== 1 ? 's' : '') + '</div>' +
      data.comments.map(c => buildComment(c, false)).join('');
  } catch(e) {
    list.innerHTML = '<div class="comment-empty">Failed to load comments.</div>';
  }
}

function toggleReply(btn, commentId, storyId) {
  const item = btn.closest('.comment-item');
  let wrap = item.querySelector('.reply-wrap');
  if (wrap) {
    wrap.style.display = wrap.style.display === 'none' ? 'flex' : 'none';
    if (wrap.style.display === 'flex') wrap.querySelector('input').focus();
    return;
  }
  wrap = document.createElement('div');
  wrap.className = 'reply-wrap';
  wrap.style.cssText = 'display:flex;gap:0.5rem;margin-top:0.5rem;';
  wrap.dataset.parentId = commentId;
  wrap.innerHTML = '<input class="comment-input" placeholder="Write a reply..." maxlength="1000" style="flex:1">' +
    '<button class="comment-submit" onclick="submitReply(this,\'' + commentId + '\',\'' + storyId + '\')">Post</button>';
  item.querySelector('.comment-body-wrap').appendChild(wrap);
  wrap.querySelector('input').focus();
}

async function submitReply(btn, parentId, storyId) {
  if (!currentUser) { requireLogin(function() {}); return; }
  const input = btn.previousElementSibling;
  const body = input.value.trim();
  if (!body) return;
  const token = localStorage.getItem('cp_token');
  try {
    const res = await fetch('/api/comments/' + storyId, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token },
      body: JSON.stringify({ body: body, parentId: parentId })
    });
    const data = await res.json();
    if (!res.ok) { showToast(data.error || 'Failed', 'error'); return; }
    input.value = '';
    btn.closest('.reply-wrap').style.display = 'none';
    await loadComments(storyId);
    showToast('Reply posted!');
  } catch(e) {
    showToast('Failed to post reply', 'error');
  }
}

async function deleteComment(commentId, storyId) {
  if (!confirm('Delete this comment?')) return;
  const token = localStorage.getItem('cp_token');
  try {
    const res = await fetch('/api/comments/' + commentId, {
      method: 'DELETE',
      headers: { 'Authorization': 'Bearer ' + token }
    });
    if (!res.ok) { showToast('Failed to delete', 'error'); return; }
    await loadComments(storyId);
    showToast('Comment deleted');
  } catch(e) {
    showToast('Failed to delete', 'error');
  }
}

function voteComment(btn, commentId, dir) {
  if (!currentUser) { requireLogin(function() {}); return; }
  const wrap = btn.closest('.comment-vote');
  const countEl = wrap.querySelector('.comment-vote-count');
  const upBtn = wrap.querySelector('.up');
  const downBtn = wrap.querySelector('.down');
  const wasActive = btn.classList.contains('active');
  const oppositeActive = dir === 1 ? downBtn.classList.contains('active') : upBtn.classList.contains('active');
  let count = parseInt(countEl.textContent) || 0;
  upBtn.classList.remove('active');
  downBtn.classList.remove('active');
  if (wasActive) {
    countEl.textContent = count - dir;
  } else {
    btn.classList.add('active');
    countEl.textContent = oppositeActive ? count + (dir * 2) : count + dir;
  }
}

async function submitComment(storyId) {
  if (!currentUser) { requireLogin(function() { submitComment(storyId); }); return; }
  const input = document.getElementById('comment-input-' + storyId);
  const body = input.value.trim();
  if (!body) return;
  const token = localStorage.getItem('cp_token');
  try {
    const res = await fetch('/api/comments/' + storyId, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token },
      body: JSON.stringify({ body: body })
    });
    const data = await res.json();
    if (!res.ok) { showToast(data.error || 'Failed to post', 'error'); return; }
    input.value = '';
    await loadComments(storyId);
  } catch(e) {
    showToast('Failed to post comment', 'error');
  }
}

