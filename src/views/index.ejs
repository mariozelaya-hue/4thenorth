let vPlaying=false,vProg=0,vInt=null;
const vTotal=1478;
function toggleVideo(){
  const c=document.getElementById('vidC');
  const btn=document.getElementById('vPlayBtn');
  const poster=document.getElementById('vPoster');
  vPlaying=!vPlaying;
  c.classList.toggle('playing',vPlaying);
