/* TOAST */
.toast{position:fixed;bottom:1.5rem;left:50%;transform:translateX(-50%) translateY(100px);background:var(--bg2);border:1px solid var(--border2);border-radius:20px;padding:0.625rem 1.25rem;font-size:0.8rem;font-weight:600;color:var(--text);z-index:2000;transition:transform 0.3s cubic-bezier(0.34,1.56,0.64,1);pointer-events:none;white-space:nowrap;}
.toast.show{transform:translateX(-50%) translateY(0);}

@media(max-width:600px){
  .btn-outline{display:none;}
  .compact-thumb{width:90px;height:62px;}
  .nl-form{flex-direction:column;}
  .lpbtns{flex-direction:column;}
}

/* TRANSLATION COMMENTARY */
.tr-line{
  font-size:0.72rem;
  line-height:1.4;
  color:var(--text3);
  margin-top:-0.25rem;
  margin-bottom:0.7rem;
  font-style:italic;
  padding-left:0;
}

/* Comment section */
.comment-section{padding:1rem 1.25rem;border-top:1px solid var(--border);background:var(--bg2);}
.comment-count-label{font-size:0.8rem;font-weight:700;color:var(--text2);margin-bottom:0.75rem;}
.comment-list{display:flex;flex-direction:column;gap:0;max-height:400px;overflow-y:auto;scrollbar-width:thin;scrollbar-color:var(--border2) transparent;}
.comment-item{display:flex;gap:0.75rem;padding:0.75rem 0;border-bottom:1px solid var(--border);}
.comment-item:last-child{border-bottom:none;}
.comment-avatar{width:30px;height:30px;border-radius:50%;background:linear-gradient(135deg,#e8354a,#c82d3e);display:flex;align-items:center;justify-content:center;font-size:0.75rem;font-weight:700;color:#fff;flex-shrink:0;}
.comment-body-wrap{flex:1;min-width:0;}
.comment-header{display:flex;align-items:center;gap:0.5rem;margin-bottom:0.3rem;}
.comment-author{font-size:0.8rem;font-weight:700;color:var(--text);}
.comment-time{font-size:0.72rem;color:var(--text3);}
.comment-text{font-size:0.875rem;color:var(--text2);line-height:1.5;margin-bottom:0.4rem;}
.comment-actions{display:flex;align-items:center;gap:0.5rem;}
.comment-vote{display:flex;align-items:center;gap:0.25rem;background:var(--bg3);border-radius:20px;padding:0.2rem 0.4rem;}
.comment-vote-btn{background:none;border:none;cursor:pointer;color:var(--text3);font-size:0.8rem;padding:0.1rem 0.25rem;transition:color 0.15s;line-height:1;}
.comment-vote-btn.up:hover,.comment-vote-btn.up.active{color:#ff6314;}
.comment-vote-btn.down:hover,.comment-vote-btn.down.active{color:#7193ff;}
.comment-vote-count{font-size:0.75rem;font-weight:700;color:var(--text2);min-width:1rem;text-align:center;}
.comment-reply-btn{background:none;border:none;cursor:pointer;color:var(--text3);font-size:0.75rem;font-weight:600;padding:0.2rem 0.5rem;border-radius:20px;transition:all 0.15s;}
.comment-reply-btn:hover{background:var(--bg3);color:var(--text);}
.comment-input-row{display:flex;gap:0.5rem;margin-top:0.75rem;padding-top:0.75rem;border-top:1px solid var(--border);}
.comment-input{flex:1;background:var(--bg3);border:1px solid var(--border);border-radius:20px;padding:0.5rem 1rem;color:var(--text);font-size:0.875rem;outline:none;}
.comment-input:focus{border-color:var(--border2);}
.comment-submit{background:#e8354a;color:#fff;border:none;border-radius:20px;padding:0.5rem 1.25rem;font-size:0.8rem;font-weight:700;cursor:pointer;}
.comment-submit:hover{background:#c82d3e;}
.comment-empty{color:var(--text3);font-size:0.875rem;text-align:center;padding:1rem 0;}

.share-menu{position:absolute;background:var(--bg2);border:1px solid var(--border);border-radius:12px;padding:0.4rem;min-width:190px;z-index:1000;box-shadow:0 8px 32px rgba(0,0,0,0.4);}
.share-menu-item{display:flex;align-items:center;gap:0.6rem;padding:0.6rem 0.75rem;border-radius:8px;cursor:pointer;color:var(--text2);font-size:0.875rem;font-weight:500;transition:all 0.15s;}
.share-menu-item:hover{background:var(--bg3);color:var(--text);}
.share-menu-divider{height:1px;background:var(--border);margin:0.3rem 0;}
</style>
