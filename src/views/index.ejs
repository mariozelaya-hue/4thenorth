// HEARTS — pill-level handler
function heartPostPill(pill,cid){
  const btn=pill.querySelector('.hbtn');
  const svg=pill.querySelector('.hsvg');
  const el=document.getElementById(cid);
  if(!el) return;
  const liked=btn.classList.contains('liked');
  btn.classList.toggle('liked',!liked);
  svg.style.fill=liked?'none':'var(--red)';
  svg.style.stroke=liked?'currentColor':'var(--red)';
  let v=parseV(el.textContent);
  v+=liked?-1:1;
  el.textContent=fmtV(v);
  showToast(liked?'Removed':'♡ Hearted!');
}
function heartX(){const e=document.getElementById('xheart');let v=parseV(e.textContent);e.textContent=fmtV(v+1);showToast('♡ Hearted!');}
function parseV(s){s=String(s).trim();if(/k$/i.test(s))return Math.round(parseFloat(s)*1000);return parseInt(s)||0;}
function fmtV(n){if(n>=1000)return(n/1000).toFixed(1).replace(/\.0$/,'')+'k';return String(n);}

