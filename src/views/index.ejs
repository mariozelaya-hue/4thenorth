<script>
let currentView = 'home';

function showExplore(term) {
  const pinned = document.getElementById("pinnedStoryCard");
  if (pinned) pinned.style.display = "none";
  currentView = 'explore';
  document.querySelectorAll('.nav-item').forEach(x => x.classList.remove('active'));
  const exploreNav = document.getElementById('nav-explore');
  if (exploreNav) exploreNav.classList.add('active');

  const container = document.getElementById('feedContainer');

  if (!term || !term.trim()) {
    container.innerHTML = `
      <div style="padding:3rem 1rem;text-align:center;">
        <div style="font-size:2rem;margin-bottom:1rem;">🔍</div>
        <div style="font-family:'DM Serif Display',serif;font-size:1.5rem;margin-bottom:0.75rem;color:var(--text);">Explore Canada's News</div>
        <div style="font-size:0.9rem;color:var(--text2);margin-bottom:1.5rem;">Search for any topic, story, or source</div>
        <div style="display:flex;gap:0.5rem;max-width:480px;margin:0 auto;">
          <input id="exploreInput" placeholder="Search Canada's news…" type="text"
            style="flex:1;padding:0.875rem 1.25rem;border-radius:12px;border:1px solid var(--border2);background:var(--bg2);color:var(--text);font-size:1rem;outline:none;font-family:'Sora',sans-serif;"
            onkeydown="if(event.key==='Enter')showExplore(this.value)">
          <button onclick="showExplore(document.getElementById('exploreInput').value)"
            style="padding:0.875rem 1.25rem;background:var(--red);border:none;border-radius:12px;color:#fff;font-weight:700;cursor:pointer;font-size:0.9rem;font-family:'Sora',sans-serif;">
            Search
          </button>
        </div>
      </div>`;
    setTimeout(() => { const inp = document.getElementById('exploreInput'); if (inp) inp.focus(); }, 50);
    return;
  }

  currentSearchTerm = term.trim();
  closeSearch(false);
  container.innerHTML = '<div style="padding:2rem;text-align:center;color:var(--text3);">Searching...</div>';

  fetch(`/api/feed/search?${new URLSearchParams({ search: currentSearchTerm, limit: 50 })}`)
    .then(r => r.json())
    .then(data => {
      if (!data.stories || data.stories.length === 0) {
        container.innerHTML = `<div style="padding:2rem;text-align:center;color:var(--text3);">No results for "<strong style="color:var(--text)">${currentSearchTerm}</strong>"<br><button onclick="showExplore()" style="margin-top:1rem;background:none;border:1px solid var(--border2);color:var(--text2);padding:0.4rem 1rem;border-radius:20px;cursor:pointer;font-family:'Sora',sans-serif;">Search again</button></div>`;
        return;
      }
      const header = `<div style="padding:0.75rem 0 1rem;color:var(--text3);font-size:0.85rem;">${data.stories.length} results for "<strong style="color:var(--text)">${currentSearchTerm}</strong>" <button onclick="goHome()" style="margin-left:0.5rem;background:none;border:1px solid #444;color:var(--text3);padding:2px 8px;border-radius:4px;cursor:pointer;font-size:0.75rem;">✕ Clear</button></div>`;
      container.innerHTML = header;
      renderStories(data, container, true);
      window.scrollTo({ top: 0, behavior: 'smooth' });
    })
    .catch(() => {
      container.innerHTML = '<div style="padding:2rem;text-align:center;color:var(--text3);">Search failed. Try again.</div>';
    });
}

function restoreLikeStates() {
  const token = localStorage.getItem("cp_token");
  if (!token || !currentUser) return;
  fetch("/api/likes", { headers: { } })
    .then(r => r.json())
    .then(data => {
      if (!data.storyIds) return;
      data.storyIds.forEach(id => {
        const pill = document.getElementById("like-" + id);
        if (pill) {
          pill.classList.add("liked");
          const btn = pill.querySelector(".hbtn");
          const svg = pill.querySelector(".hsvg");
          if (btn) btn.style.color = "#e8354a";
          if (svg) { svg.style.fill = "var(--red)"; svg.style.stroke = "var(--red)"; }
        }
      });
    })
    .catch(() => {});
}

function restoreSaveStates() {
  const token = localStorage.getItem("cp_token");
  if (!token || !currentUser) return;
  fetch("/api/saves", { headers: { } })
    .then(r => r.json())
    .then(data => {
      if (!data.stories) return;
      data.stories.forEach(s => {
        const btn = document.getElementById("save-" + s.id);
        if (btn) {
          btn.classList.add("saved");
          btn.style.color = "var(--gold)";
          btn.style.borderColor = "rgba(245,166,35,0.3)";
        }
      });
    })
    .catch(() => {});
}

function goHome() {
  const pinned = document.getElementById("pinnedStoryCard");
  if (pinned) pinned.style.display = "";
  currentView = 'home';
  currentSearchTerm = '';
  document.querySelectorAll('.nav-item').forEach(x => x.classList.remove('active'));
  document.querySelector('.nav-item:first-child').classList.add('active');
  loadFeed();
}
</script>

<script>
const avatarColors = ["#e8354a","#4a9eff","#2ecc71","#f5a623","#9b59b6","#e67e22","#1abc9c","#e91e63"];

function getAvatarColor(username) {
  let hash = 0;
  for (let i = 0; i < username.length; i++) hash = username.charCodeAt(i) + ((hash << 5) - hash);
  return avatarColors[Math.abs(hash) % avatarColors.length];
}

function toggleProfileDropdown() {
  const dd = document.getElementById("profileDropdown");
  dd.classList.toggle("open");
  if (dd.classList.contains("open")) {
    setTimeout(() => document.addEventListener("click", closeProfileDropdown, { once: true }), 0);
  }
}

function closeProfileDropdown() {
  const dd = document.getElementById("profileDropdown");
  if (dd) dd.classList.remove("open");
}

function showSavedFromProfile() {
  closeProfileDropdown();
  requireLogin(() => showSaved(null));
}

function showLikedFromProfile() {
  closeProfileDropdown();
  showLiked();
}

function showProfileSettings() {
  closeProfileDropdown();
  openSettings();
}

async function showLiked(el) {
  document.querySelectorAll(".nav-item").forEach(x => x.classList.remove("active"));
  if (el) el.classList.add("active");
  const pinned = document.getElementById("pinnedStoryCard");
  if (pinned) pinned.style.display = "none";
  const container = document.getElementById("feedContainer");
  container.innerHTML = '<div style="padding:2rem;text-align:center;color:var(--text3);">Loading liked stories...</div>';
  try {
    const res = await fetch("/api/likes", { headers: { } });
    const data = await res.json();
    if (!data.storyIds || data.storyIds.length === 0) {
      container.innerHTML = '<div style="padding:2rem;text-align:center;color:var(--text3);">No liked stories yet.</div>';
      return;
    }
    const feedRes = await fetch("/api/feed?limit=50");
    const feedData = await feedRes.json();
    const liked = feedData.stories.filter(s => data.storyIds.includes(s.id));
    if (liked.length === 0) {
      container.innerHTML = '<div style="padding:2rem;text-align:center;color:var(--text3);">No liked stories found.</div>';
      return;
    }
    renderStories({ stories: liked }, container);
    setTimeout(restoreLikeStates, 100);
    setTimeout(restoreSaveStates, 100);
  } catch(e) {
    container.innerHTML = '<div style="padding:2rem;text-align:center;color:var(--text3);">Failed to load.</div>';
  }
}
</script>

<style>
