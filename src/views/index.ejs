<header class="header">
  <div class="header-inner">
    <a href="#" class="logo">CanadianPulse</a>
    <div class="header-spacer"></div>
    <button class="theme-toggle" onclick="toggleTheme()" title="Toggle theme"><span id="themeIcon">☀️</span></button>
    <button class="search-icon-btn" onclick="openSearch()" title="Search">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
    </button>
    <div class="hbtns" id="authArea">

      <button class="btn-outline" id="loginBtn" onclick="openModal('login')">Log In</button>
      <button class="btn-red" id="joinBtn" onclick="openModal('signup')">Join Free</button>
    </div>
    <div class="profile-wrap" id="profileWrap" style="display:none;">
      <button class="profile-btn" onclick="toggleProfileDropdown()">
        <div class="profile-avatar" id="profileAvatar">U</div>
        <span class="profile-name" id="profileName">User</span>
      </button>
      <div class="profile-dropdown" id="profileDropdown">
        <div class="pd-header"><div class="pd-username" id="pdUsername"></div><div class="pd-email" id="pdEmail"></div></div>
        <div class="pd-item" onclick="showSavedFromProfile()">📌 Saved Stories</div>
        <div class="pd-item" onclick="showLikedFromProfile()">❤️ Liked Stories</div>
        <div class="pd-divider"></div>
        <div class="pd-item" onclick="showProfileSettings()">⚙️ Settings</div>
        <div class="pd-divider"></div>
        <div class="pd-item red" onclick="logout()">Log Out</div>
      </div>
    </div>
    </div>
  </div>
</header>

<!-- SEARCH OVERLAY -->
<div class="search-overlay" id="searchOverlay" onclick="if(event.target===this)closeSearch()">
  <div class="search-overlay-inner">
    <div class="search-input-wrap">
      <input class="search-overlay-input" id="searchInput" placeholder="Search Canada's news…" type="text" autofocus onkeydown="if(event.key==='Enter')executeSearch(this.value)" oninput="liveSearch(this.value)">
      <button class="search-close-btn" onclick="closeSearch()">✕</button>
    </div>
    <div id="searchDropdown" style="display:none;background:var(--bg2);border:1px solid var(--border);border-radius:8px;margin-top:0.5rem;overflow:hidden;"></div>
