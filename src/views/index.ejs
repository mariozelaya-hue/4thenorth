async function loadComments(storyId) {
  const list = document.getElementById('comment-list-' + storyId);
  if (!list) return;
  list.innerHTML = '<div class="comment-empty">Loading...</div>';
  try {
    const res = await fetch('/api/comments/' + storyId);
    const data = await res.json();
    if (!data.comments || data.comments.length === 0) {
      list.innerHTML = '<div class="comment-empty">No comments yet. Be the first!</div>';
      return;
    }
    function buildComment(c, isReply) {
      const replies = (!isReply && c.replies && c.replies.length) 
        ? '<div class="comment-replies">' + c.replies.map(r => buildComment(r, true)).join('') + '</div>' 
        : '';
      return '<div class="comment-item' + (isReply ? ' comment-reply' : '') + '">' +
        '<div class="comment-avatar">' + c.user.username[0].toUpperCase() + '</div>' +
        '<div class="comment-body-wrap">' +
        '<div class="comment-header"><span class="comment-author">' + c.user.username + '</span><span class="comment-time">' + getTimeAgo(c.createdAt) + '</span></div>' +
        '<div class="comment-text">' + c.body + '</div>' +
        '<div class="comment-actions">' +
        '<div class="comment-vote">' +
        '<button class="comment-vote-btn up" onclick="voteComment(this,\'' + c.id + '\',1)">▲</button>' +
        '<span class="comment-vote-count">' + (c.likes || 0) + '</span>' +
        '<button class="comment-vote-btn down" onclick="voteComment(this,\'' + c.id + '\',-1)">▼</button>' +
        '</div>' +
        (isReply ? '' : '<button class="comment-reply-btn" onclick="toggleReply(this,\'' + c.id + '\',\'' + storyId + '\')">Reply</button>') +
        (currentUser && currentUser.id === c.userId ? '<button class="comment-reply-btn" style="color:#e8354a" onclick="deleteComment(\'' + c.id + '\',\'' + storyId + '\')">Delete</button>' : '') +
        '</div>' +
        replies +
        '</div></div>';
    }
    list.innerHTML = '<div class="comment-count-label">' + data.comments.length + ' comment' + (data.comments.length !== 1 ? 's' : '') + '</div>' +
      data.comments.map(c => buildComment(c, false)).join('');
  } catch(e) {
    list.innerHTML = '<div class="comment-empty">Failed to load comments.</div>';
  }
}

function toggleReply(btn, commentId, storyId) {
