<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>4TheNorth Admin - Login</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: #0f1419; color: #e7e9ea; min-height: 100vh; display: flex; align-items: center; justify-content: center; }
    .login-box { background: #1a1f25; border: 1px solid #2f3942; border-radius: 12px; padding: 40px; width: 100%; max-width: 400px; }
    .login-box h1 { font-size: 24px; margin-bottom: 8px; color: #fff; }
    .login-box p { color: #71767b; font-size: 14px; margin-bottom: 24px; }
    label { display: block; font-size: 13px; color: #71767b; margin-bottom: 6px; text-transform: uppercase; letter-spacing: 0.5px; }
    input[type="text"], input[type="password"] { width: 100%; padding: 12px; background: #0f1419; border: 1px solid #2f3942; border-radius: 6px; color: #e7e9ea; font-size: 15px; margin-bottom: 16px; }
    input:focus { outline: none; border-color: #d94f00; }
    button { width: 100%; padding: 12px; background: #d94f00; color: #fff; border: none; border-radius: 6px; font-size: 15px; font-weight: 600; cursor: pointer; }
    button:hover { background: #c44500; }
    .error { background: #3d1c1c; border: 1px solid #d94f00; color: #ff6b6b; padding: 10px 14px; border-radius: 6px; font-size: 14px; margin-bottom: 16px; }
  </style>
</head>
<body>
  <div class="login-box">
    <h1>4TheNorth</h1>
    <p>Admin Dashboard</p>
    <% if (error) { %>
      <div class="error"><%= error %></div>
    <% } %>
    <form method="POST" action="/admin/login">
      <label>Username</label>
      <input type="text" name="username" required autofocus>
      <label>Password</label>
      <input type="password" name="password" required>
      <button type="submit">Sign In</button>
    </form>
  </div>
</body>
</html>
