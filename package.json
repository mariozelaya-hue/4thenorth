{
  "name": "4thenorth",
  "version": "1.0.0",
  "description": "4TheNorth - Canadian news aggregation with AI editorial voice",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "db:push": "npx prisma db push",
    "db:seed": "node scripts/seed-admin.js",
    "db:studio": "npx prisma studio",
    "setup": "npm install && npx prisma generate && npx prisma db push && node scripts/seed-admin.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@prisma/client": "^6.4.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "ejs": "^3.1.10",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "express-validator": "^7.2.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "node-cache": "^5.1.2",
    "open-graph-scraper": "^6.9.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.9",
    "prisma": "^6.4.0"
  }
}
