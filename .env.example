# ===========================================
# 4TheNorth - Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values

# Database (PostgreSQL)
# Railway: use the DATABASE_URL from Railway dashboard
# Local: postgresql://user:password@localhost:5432/forthenorth
DATABASE_URL="postgresql://user:password@localhost:5432/forthenorth"

# Anthropic Claude API
ANTHROPIC_API_KEY="sk-ant-your-key-here"

# JWT Secret (generate a random string: openssl rand -hex 32)
JWT_SECRET="change-this-to-a-random-64-char-string"

# Server
PORT=3000
NODE_ENV="development"

# Frontend URL (for CORS)
FRONTEND_URL="http://localhost:3000"

# Admin credentials (used by seed script only)
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="changeme123"
