generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum StoryStatus {
  pending
  published
  rejected
}

model Story {
  id                  String      @id @default(uuid())
  originalTitle       String      @map("original_title")
  originalDescription String?     @map("original_description")
  editorialTag        String?     @map("editorial_tag") @db.VarChar(50)
  commentary          String?
  sourceName          String?     @map("source_name") @db.VarChar(100)
  sourceUrl           String      @map("source_url")
  imageUrl            String?     @map("image_url")
  publishedAt         DateTime?   @map("published_at")
  sourcePublishedAt   DateTime?   @map("source_published_at")
  status              StoryStatus @default(pending)
  viralScore          Decimal     @default(5.0) @map("viral_score") @db.Decimal(3, 1)
  likes               Int         @default(0)
  dislikes            Int         @default(0)
  views               Int         @default(0)
  aiConfidence        Decimal?    @map("ai_confidence") @db.Decimal(3, 2)
  aiAlternatives      Json?       @map("ai_alternatives")
  category            String?     @db.VarChar(50)
  isFeatured          Boolean     @default(false) @map("is_featured")
  isBreaking          Boolean     @default(false) @map("is_breaking")
  sourceHash          String      @unique @map("source_hash") @db.VarChar(64)
  createdAt           DateTime    @default(now()) @map("created_at")
  updatedAt           DateTime    @updatedAt @map("updated_at")

  @@map("stories")
  @@index([status, publishedAt(sort: Desc)])
  @@index([category])
}

model AdminUser {
  id           String   @id @default(uuid())
  username     String   @unique @db.VarChar(50)
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("admin_users")
}

model NewsletterSubscriber {
  id           String   @id @default(uuid())
  email        String   @unique @db.VarChar(255)
  subscribedAt DateTime @default(now()) @map("subscribed_at")
  isActive     Boolean  @default(true) @map("is_active")
  source       String?  @db.VarChar(50)

  @@map("newsletter_subscribers")
}

model AuditLog {
  id        String   @id @default(uuid())
  action    String   @db.VarChar(100)
  actor     String   @db.VarChar(50)
  details   Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("audit_log")
  @@index([createdAt(sort: Desc)])
}

model Setting {
  id    String @id @default(uuid())
  key   String @unique @db.VarChar(100)
  value String @db.Text

  @@map("settings")
}
