generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum StoryStatus {
  pending
  published
  rejected
}

model Story {
  id                  String      @id @default(uuid())
  originalTitle       String      @map("original_title")
  originalDescription String?     @map("original_description")
  editorialTag        String?     @map("editorial_tag") @db.VarChar(50)
  commentary          String?
  sourceName          String?     @map("source_name") @db.VarChar(100)
  sourceUrl           String      @map("source_url")
  imageUrl            String?     @map("image_url")
  publishedAt         DateTime?   @map("published_at")
  sourcePublishedAt   DateTime?   @map("source_published_at")
  status              StoryStatus @default(pending)
  viralScore          Decimal     @default(5.0) @map("viral_score") @db.Decimal(3, 1)
  likes               Int         @default(0)
  dislikes            Int         @default(0)
  views               Int         @default(0)
  aiConfidence        Decimal?    @map("ai_confidence") @db.Decimal(3, 2)
  aiAlternatives      Json?       @map("ai_alternatives")
  category            String?     @db.VarChar(50)
  isFeatured          Boolean     @default(false) @map("is_featured")
  isBreaking          Boolean     @default(false) @map("is_breaking")
  cardStyle           String?     @default("")
  tags                String[]    @default([])
  sourceHash          String      @unique @map("source_hash") @db.VarChar(64)
  createdAt           DateTime    @default(now()) @map("created_at")
  updatedAt           DateTime    @updatedAt @map("updated_at")

  savedBy     SavedStory[]

  @@map("stories")
  @@index([status, publishedAt(sort: Desc)])
  @@index([category])
}

model AdminUser {
  id           String   @id @default(uuid())
  username     String   @unique @db.VarChar(50)
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("admin_users")
}

model NewsletterSubscriber {
  id           String   @id @default(uuid())
  email        String   @unique @db.VarChar(255)
  subscribedAt DateTime @default(now()) @map("subscribed_at")
  isActive     Boolean  @default(true) @map("is_active")
  source       String?  @db.VarChar(50)

  @@map("newsletter_subscribers")
}

model AuditLog {
  id        String   @id @default(uuid())
  action    String   @db.VarChar(100)
  actor     String   @db.VarChar(50)
  details   Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("audit_log")
  @@index([createdAt(sort: Desc)])
}

model Setting {
  id    String @id @default(uuid())
  key   String @unique @db.VarChar(100)
  value String @db.Text

  @@map("settings")
}

model User {
  id           String    @id @default(uuid())
  username     String    @unique @db.VarChar(50)
  email        String    @unique @db.VarChar(255)
  passwordHash String    @map("password_hash")
  avatarUrl    String?   @map("avatar_url")
  createdAt    DateTime  @default(now()) @map("created_at")
  comments     Comment[]
  savedStories SavedStory[]

  @@map("users")
}

model Comment {
  id        String    @id @default(uuid())
  storyId   String    @map("story_id")
  userId    String    @map("user_id")
  parentId  String?   @map("parent_id")
  body      String    @db.VarChar(1000)
  likes     Int       @default(0)
  createdAt DateTime  @default(now()) @map("created_at")
  user      User      @relation(fields: [userId], references: [id])
  parent    Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies   Comment[] @relation("CommentReplies")

  @@map("comments")
}

model SavedStory {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  storyId   String   @map("story_id")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id])
  story     Story    @relation(fields: [storyId], references: [id])

  @@unique([userId, storyId])
  @@map("saved_stories")
}
